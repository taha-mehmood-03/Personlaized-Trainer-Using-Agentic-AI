// Prisma schema for Mental Health Wellness - LangGraph Version
// Database: PostgreSQL with Supabase
// Optimized: 12 models with proper normalization

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS - Type Safety
// ============================================

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum Emotion {
  ANGER
  DISGUST
  FEAR
  JOY
  NEUTRAL
  SADNESS
  SURPRISE
  ANXIETY
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum CrisisRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ConversationPhase {
  VENTING
  REFLECTION
  SOLUTION
  RECOVERY
}

enum AgentRole {
  FRIEND
  COACH
  TRAINER
  CRISIS_SUPPORT
}

enum Difficulty {
  EASY
  MODERATE
  HARD
}

enum ClinicalSeverity {
  MINIMAL
  MILD
  MODERATE
  MODERATELY_SEVERE
  SEVERE
}

// Turn type for per-turn EmotionSnapshot — drives turn-aware improvement analysis
enum TurnType {
  INITIAL_DISCLOSURE
  FOLLOW_UP_DISCLOSURE
  CONTEXT_GATHERING
  POST_RECOMMENDATION_REACTION
  CRISIS_DISCLOSURE
}

enum SleepQuality {
  POOR
  FAIR
  GOOD
  GREAT
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum DataSensitivity {
  PUBLIC
  PERSONAL
  SENSITIVE
  PHI
}

enum LegalBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  VITAL_INTERESTS
  PUBLIC_TASK
  LEGITIMATE_INTERESTS
  HEALTH_CARE
}

enum ConsentScope {
  WELLNESS_CHAT
  MOOD_ANALYTICS
  PERSONALIZATION
  CRISIS_SAFETY
  CRISIS_LOCATION
  EMERGENCY_CONTACT_ALERTS
  VOICE_ANALYSIS
  RESEARCH_EXPORT
}

enum AuditEventType {
  AUTH_LOGIN
  AUTH_SIGNUP
  DATA_ACCESS
  DATA_EXPORT
  DATA_ERASURE
  CONSENT_GRANTED
  CONSENT_WITHDRAWN
  SESSION_DELETE
  SECURITY_EVENT
}

enum DataSubjectRequestType {
  ACCESS
  ERASURE
  RECTIFICATION
  RESTRICTION
  PORTABILITY
  OBJECTION
  CONSENT_WITHDRAWAL
}

enum DataSubjectRequestStatus {
  RECEIVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  consentGiven Boolean  @default(false)
  consentDate  DateTime?
  consentVersion String?
  privacyNoticeVersion String?
  termsVersion String?
  processingRegion String?
  dataRetentionDays Int @default(365)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  sessions          Session[]
  moodLogs          MoodLog[]
  techniqueRatings  UserTechniqueRating[]
  crisisLogs        CrisisLog[]
  emergencyContacts EmergencyContact[]
  preference        UserPreference?
  statistics        UserStatistics?

  // v3: New intelligent subsystems
  psychProfile           PsychProfile?

  // ChatGPT-style memory layers
  facts              UserFact[]
  sessionSummaries   SessionSummary[]

  @@index([email])
}

// ============================================
// CONVERSATION MODELS
// ============================================

model Session {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String        @default("New Conversation")
  status      SessionStatus @default(ACTIVE)
  moodSummary Sentiment?
  phase       ConversationPhase @default(VENTING)
  
  // Agent behavior personalization (NEW - NODE 4.5)
  agentRole   AgentRole     @default(COACH)  // friend | coach | trainer | crisis_support
  
  // LangGraph checkpoint data (for memory)
  checkpointData String?    @db.Text
  sensitivity DataSensitivity @default(SENSITIVE)
  retentionUntil DateTime?
  peakIntensity Float?
  peakIntensityTurnType TurnType?
  
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  
  // Relationships
  messages          Message[]
  moodLog           MoodLog?
  summaries             SessionSummary[]
  techniqueOutcomes     TechniqueOutcome[]
  clinicalAssessments  ClinicalAssessmentLog[]
  techniqueRatings      UserTechniqueRating[]

  // v3: Emotion trajectory snapshots
  emotionSnapshots  EmotionSnapshot[]

  @@index([userId])
  @@index([startedAt])
  @@index([status])
  @@index([agentRole])
}

model Message {
  id          String      @id @default(cuid())
  sessionId   String
  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role        MessageRole
  content     String      @db.Text
  sensitivity DataSensitivity @default(SENSITIVE)
  retentionUntil DateTime?
  piiRedacted Boolean @default(false)
  
  // Mood analysis (for USER messages)
  emotion     Emotion?
  intensity   Float?
  sentiment   Sentiment?
  confidence  Float?
  primarySubEmotion String?
  secondarySubEmotions String[] @default([])
  detectedSymptoms String[] @default([])
  detectedBehaviors String[] @default([])
  detectedContexts String[] @default([])
  emotionScores Json?
  
  // Technique recommended (for ASSISTANT messages)
  techniqueId String?
  technique   Technique?  @relation(fields: [techniqueId], references: [id])
  techniqueOfferedThisTurn Boolean @default(false)
  
  // Voice analysis (optional - only when voice input used)
  voiceEmotion    String?
  voiceArousal    Float?
  voiceValence    Float?
  voiceConfidence Float?
  
  createdAt   DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@index([emotion])
}

// ============================================
// MOOD TRACKING
// ============================================

model MoodLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Optional link to session (mood detected during chat)
  sessionId String?   @unique
  session   Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  
  emotion   Emotion
  intensity Float
  sentiment Sentiment
  primarySubEmotion String?
  secondarySubEmotions String[] @default([])
  detectedSymptoms String[] @default([])
  detectedBehaviors String[] @default([])
  detectedContexts String[] @default([])
  emotionScores Json?
  
  // Context
  context   String?
  notes     String?
  sensitivity DataSensitivity @default(SENSITIVE)
  retentionUntil DateTime?
  
  // Analysis metadata
  method    String    @default("distilroberta")
  
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([emotion])
}

// ============================================
// TECHNIQUE MODELS
// ============================================

model TechniqueCategory {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String?
  
  techniques  Technique[]
}

model Technique {
  id              String            @id @default(cuid())
  categoryId      String
  category        TechniqueCategory @relation(fields: [categoryId], references: [id])
  
  name            String
  description     String
  brief           String
  steps           String[]
  
  durationMinutes Int
  difficulty      Difficulty
  
  targetEmotions  Emotion[]
  targetSubEmotions String[] @default([])
  targetSymptoms    String[] @default([])
  targetBehaviors   String[] @default([])
  avoidSubEmotions  String[] @default([])
  avoidSymptoms     String[] @default([])
  avoidBehaviors    String[] @default([])
  minIntensity      Float    @default(0.0)
  maxIntensity      Float    @default(1.0)
  pacingTier        String   @default("normal")
  deliveryMode      String   @default("exercise")
  bestForContexts   String[] @default([])
  
  whyItWorks      String?
  
  avgRating       Float             @default(0)
  totalRatings    Int               @default(0)
  effectiveness   Float             @default(0.5)
  
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())

  // v9.0: Clinical severity gating (PHQ-9/GAD-7)
  minPhq9              Int       @default(0)     // minimum PHQ-9 score this technique is appropriate for
  maxPhq9              Int       @default(27)    // maximum PHQ-9 score this technique is appropriate for
  safeAtSeverity       String[]  @default(["MINIMAL", "MILD", "MODERATE", "MODERATELY_SEVERE"])
  contraindicatedFlags String[]  @default([])    // e.g. ["suicidal_ideation", "psychomotor"]
  
  userRatings     UserTechniqueRating[]
  recommendedIn   Message[]
  outcomes        TechniqueOutcome[]

  @@index([categoryId])
  @@index([isActive])
}

model UserTechniqueRating {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  techniqueId String
  technique   Technique @relation(fields: [techniqueId], references: [id], onDelete: Cascade)
  
  rating      Int?
  feedback    String?
  completed   Boolean   @default(false)
  
  usedAt      DateTime  @default(now())

  sessionId   String?
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([techniqueId])
  @@index([rating])
  @@index([sessionId])
}

// ============================================
// CRISIS & SAFETY MODELS
// ============================================

model CrisisLog {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  riskLevel             CrisisRiskLevel
  triggeredKeywords     String[]
  messageContent        String          @db.Text
  sensitivity           DataSensitivity @default(PHI)
  retentionUntil        DateTime?
  
  actionTaken           String
  resourcesProvided     Boolean         @default(false)
  humanHandoffRequested Boolean         @default(false)
  
  createdAt             DateTime        @default(now())

  @@index([userId])
  @@index([riskLevel])
  @@index([createdAt])
}

// ============================================
// USER SETTINGS & ANALYTICS
// ============================================

model UserPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  communicationStyle   String   @default("empathetic")
  detailLevel          String   @default("moderate")
  tone                 String   @default("warm")
  language             String   @default("en-US")
  timezone             String   @default("UTC")
  
  dailyCheckInEnabled  Boolean  @default(true)
  dailyCheckInTime     String   @default("09:00")
  moodRemindersEnabled Boolean  @default(true)
  sessionAutoSave      Boolean  @default(true)
  anonymousMode        Boolean  @default(false)
  
  preferredCategories  String[] @default([])
  crisisLocationConsent Boolean  @default(false)
  emergencyContactConsent Boolean @default(false)
  voiceAnalysisConsent Boolean @default(false)
  
  theme                String   @default("light")
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model UserStatistics {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  currentCheckInStreak Int      @default(0)
  longestCheckInStreak Int      @default(0)
  
  totalSessions        Int      @default(0)
  totalMessages        Int      @default(0)
  totalCheckIns        Int      @default(0)
  totalTechniquesUsed  Int      @default(0)
  
  averageMoodRating    Float    @default(5.0)
  mostCommonEmotion    Emotion  @default(NEUTRAL)
  
  mostUsedTechniqueId  String?
  avgTechniqueRating   Float    @default(0)
  
  lastSessionAt        DateTime?
  lastCheckInAt        DateTime?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ============================================
// WORLD-CLASS INTELLIGENCE MODELS
// ============================================

model SessionSummary {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ChatGPT-style summary fields
  title      String
  summary    String   @db.Text
  sensitivity DataSensitivity @default(SENSITIVE)
  retentionUntil DateTime?
  emotion    String   @default("neutral")
  techniques String[]
  outcome    String   @default("neutral")
  finalEmotion String?
  finalIntensity Float?
  techniqueOffered Json?
  turnTypeCounts Json?

  // Legacy field kept for backward compat
  keyThemes  String[]

  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// CHATGPT-STYLE MEMORY: EXPLICIT FACTS
// ============================================

model UserFact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fact      String
  category  String   // identity | preference | goal | clinical | context
  sensitivity DataSensitivity @default(SENSITIVE)
  legalBasis LegalBasis @default(CONSENT)
  retentionUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

model TechniqueOutcome {
  id              String    @id @default(cuid())
  sessionId       String
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  techniqueId     String
  technique       Technique @relation(fields: [techniqueId], references: [id])
  emotionBefore   Emotion
  emotionAfter    Emotion?
  subEmotionBefore String?
  subEmotionAfter  String?
  symptomsBefore String[] @default([])
  symptomsAfter  String[] @default([])
  behaviorsBefore String[] @default([])
  behaviorsAfter  String[] @default([])
  intensityBefore Float
  intensityAfter  Float?
  effectiveness   Float?
  followThrough   Boolean?
  confidence      Float?
  interventionType String?  @default("technique_delivery")
  createdAt       DateTime  @default(now())

  @@index([sessionId])
  @@index([techniqueId])
}

// ============================================
// v3: INTELLIGENT SUBSYSTEM MODELS
// ============================================

model PsychProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Coping architecture
  copingStyle       String   @default("avoidant")   // avoidant | proactive | mixed
  techniqueAccRate  Float    @default(0.5)           // ratio of techniques accepted
  reflectionDepth   Float    @default(0.5)           // 0=venting only, 1=deeply reflective

  // Emotional landscape
  anxietyBaseline   Float    @default(0.5)           // EMA of recent anxiety intensity
  resilienceScore   Float    @default(0.5)           // improves with positive trajectories
  dominantEmotion   String   @default("neutral")     // most common emotion
  emotionalTriggers String[]                         // e.g. ["work", "family", "social"]

  // Social & motivational
  motivationType    String   @default("external")   // external | internal | mixed
  socialDependency  Float    @default(0.5)           // social keyword frequency score

  // Distortion history
  topDistortions    String[]                         // e.g. ["catastrophizing", "mind_reading"]
  distortionCount   Int      @default(0)             // lifetime detected distortions

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model EmergencyContact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  phone     String
  relation  String?
  channel   String   @default("sms")
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([phone])
}

model EmotionSnapshot {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String

  turn           Int
  emotion        Emotion
  intensity      Float
  sentiment      Sentiment
  primarySubEmotion String?
  secondarySubEmotions String[] @default([])
  detectedSymptoms String[] @default([])
  detectedBehaviors String[] @default([])
  detectedContexts String[] @default([])
  emotionScores Json?
  distortionType String?
  phase          ConversationPhase?
  conversationPhase String?
  responseStrategy String?

  // Turn classification — drives turn-type-filtered trend calculation
  turnType  TurnType?
  techniqueOfferedThisTurn Boolean @default(false)
  techniqueId String?
  mismatch Boolean @default(false)
  possibleMasking Boolean @default(false)
  fusionConfidence Float?
  transcriptionConfidence Float?
  voiceFeatureSnapshot Json?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([turnType])
}

// ============================================
// v9.0: CLINICAL ASSESSMENT LOG (PHQ-9/GAD-7)
// ============================================

model ClinicalAssessmentLog {
  id               String            @id @default(cuid())
  sessionId        String
  session          Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           String

  severity         ClinicalSeverity
  phq9Score        Int               // estimated PHQ-9 total (0-27)
  gad7Score        Int               // estimated GAD-7 total (0-21)
  indicators       String[]          // clinical indicators scoring >= 2
  confidence       Float             // 0.0-1.0 confidence in assessment
  justification    String?           // LLM reasoning for the severity
  sensitivity      DataSensitivity   @default(PHI)
  retentionUntil   DateTime?

  assessedAt       DateTime          @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([assessedAt])
}

// ============================================
// COMPLIANCE, CONSENT, AND PRIVACY GOVERNANCE
// ============================================

model ConsentRecord {
  id               String       @id @default(cuid())
  userId           String
  userIdHash       String
  scope            ConsentScope
  granted          Boolean
  legalBasis       LegalBasis   @default(CONSENT)
  policyVersion    String
  noticeVersion    String
  termsVersion     String
  locale           String?
  processingRegion String?
  ipHash           String?
  userAgentHash    String?
  recordedAt       DateTime     @default(now())

  @@index([userId])
  @@index([userIdHash])
  @@index([scope])
  @@index([recordedAt])
}

model AuditEvent {
  id                String         @id @default(cuid())
  eventType         AuditEventType
  actorUserIdHash   String?
  subjectUserIdHash String?
  resourceType      String?
  resourceIdHash    String?
  action            String
  purpose           String?
  legalBasis        LegalBasis?
  status            String         @default("SUCCESS")
  ipHash            String?
  userAgentHash     String?
  metadata          Json?
  createdAt         DateTime       @default(now())

  @@index([subjectUserIdHash])
  @@index([eventType])
  @@index([createdAt])
}

model DataSubjectRequest {
  id              String                   @id @default(cuid())
  userId          String
  userIdHash      String
  type            DataSubjectRequestType
  status          DataSubjectRequestStatus @default(RECEIVED)
  requestedAt     DateTime                 @default(now())
  completedAt     DateTime?
  requestMetadata Json?
  resolutionNotes String?

  @@index([userId])
  @@index([userIdHash])
  @@index([type])
  @@index([status])
  @@index([requestedAt])
}

model DataRetentionPolicy {
  id              String          @id @default(cuid())
  dataClass       DataSensitivity
  resourceType    String
  retentionDays   Int
  legalBasis      LegalBasis
  description     String
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([dataClass, resourceType])
  @@index([isActive])
}
